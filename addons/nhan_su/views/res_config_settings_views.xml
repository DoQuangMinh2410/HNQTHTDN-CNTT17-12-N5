<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.nhan_su</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="30"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="Nhân Sự &amp; Thông Báo" string="Nhân Sự &amp; Thông Báo" data-key="nhan_su">
                    <h2>Cấu hình Telegram</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="telegram_bot_token"/>
                                <field name="telegram_bot_token" password="True"/>
                                <div class="text-muted">Nhập Token từ @BotFather.</div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="telegram_chat_id"/>
                                <field name="telegram_chat_id"/>
                                <div class="text-muted">ID người nhận hoặc Group ID.</div>
                                <div class="mt8">
                                    <button name="action_test_telegram_connection" icon="fa-paper-plane text-primary" type="object" string="Kiểm tra kết nối" class="btn-link"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <record id="action_hndn_config_settings" model="ir.actions.act_window">
        <field name="name">Cấu hình hệ thống</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'nhan_su'}</field>
    </record>
</odoo>
