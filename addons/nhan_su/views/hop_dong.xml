<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ===== FORM VIEW ===== -->
        <record id="view_hop_dong_form" model="ir.ui.view">
            <field name="name">hop_dong.form</field>
            <field name="model">hop_dong</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_cham_dut" string="Chấm dứt hợp đồng"
                                type="object" class="btn-danger"
                                attrs="{'invisible': [('trang_thai','in',['cham_dut','het_han'])]}"/>
                        <field name="trang_thai" widget="statusbar"
                               statusbar_visible="nhap,hieu_luc,het_han,cham_dut"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="ma_hop_dong"/>
                            <h1><field name="ma_hop_dong" readonly="1" force_save="1"/></h1>
                        </div>
                        <group>
                            <group string="Thông tin hợp đồng">
                                <field name="nhan_vien_id"/>
                                <field name="loai_hop_dong"/>
                                <field name="ngay_bat_dau"/>
                                <field name="ngay_ket_thuc"
                                       attrs="{'invisible': [('loai_hop_dong','=','khong_xac_dinh_thoi_han')]}"/>
                            </group>
                            <group string="Thông tin lương">
                                <field name="luong_co_ban" widget="monetary"
                                       options="{'currency_field': False}"/>
                                <field name="he_so_luong"/>
                            </group>
                        </group>
                        <group string="Ghi chú">
                            <field name="ghi_chu" nolabel="1" colspan="2"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ===== TREE VIEW ===== -->
        <record id="view_hop_dong_tree" model="ir.ui.view">
            <field name="name">hop_dong.tree</field>
            <field name="model">hop_dong</field>
            <field name="arch" type="xml">
                <tree decoration-success="trang_thai == 'hieu_luc'"
                      decoration-warning="trang_thai == 'nhap'"
                      decoration-muted="trang_thai in ['het_han','cham_dut']">
                    <field name="ma_hop_dong"/>
                    <field name="nhan_vien_id"/>
                    <field name="loai_hop_dong"/>
                    <field name="ngay_bat_dau"/>
                    <field name="ngay_ket_thuc"/>
                    <field name="luong_co_ban"/>
                    <field name="he_so_luong"/>
                    <field name="trang_thai" widget="badge"
                           decoration-success="trang_thai == 'hieu_luc'"
                           decoration-warning="trang_thai == 'nhap'"
                           decoration-danger="trang_thai in ['het_han','cham_dut']"/>
                </tree>
            </field>
        </record>

        <record id="view_hop_dong_search" model="ir.ui.view">
            <field name="name">hop_dong.search</field>
            <field name="model">hop_dong</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm hợp đồng">
                    <field name="ma_hop_dong"/>
                    <field name="nhan_vien_id"/>
                    <separator/>
                    <filter string="Đang hiệu lực" name="hieu_luc" domain="[('trang_thai','=','hieu_luc')]"/>
                    <filter string="Hết hạn" name="het_han" domain="[('trang_thai','=','het_han')]"/>
                    <group expand="0" string="Nhóm theo">
                        <filter string="Loại hợp đồng" name="group_loai" context="{'group_by': 'loai_hop_dong'}"/>
                        <filter string="Trạng thái" name="group_trang_thai" context="{'group_by': 'trang_thai'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_hop_dong" model="ir.actions.act_window">
            <field name="name">Hợp đồng lao động</field>
            <field name="res_model">hop_dong</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_hop_dong_search"/>
        </record>
    </data>
</odoo>
