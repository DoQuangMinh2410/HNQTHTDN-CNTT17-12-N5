<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ===== FORM VIEW ===== -->
        <record id="view_cham_cong_form" model="ir.ui.view">
            <field name="name">cham_cong.form</field>
            <field name="model">cham_cong</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="display_name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group string="Thông tin kỳ chấm công">
                                <field name="nhan_vien_id"/>
                                <field name="thang"/>
                                <field name="nam"/>
                                <field name="so_ngay_cong_chuan"/>
                            </group>
                            <group string="Kết quả chấm công">
                                <field name="so_ngay_cong_thuc_te"/>
                                <field name="so_ngay_nghi_phep"/>
                                <field name="so_ngay_nghi_le"/>
                                <field name="so_ngay_nghi_khong_luong"/>
                                <field name="so_gio_lam_them"/>
                                <field name="he_so_cong" widget="progressbar"/>
                            </group>
                        </group>
                        <group string="Ghi chú">
                            <field name="ghi_chu" nolabel="1" colspan="2"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ===== TREE VIEW ===== -->
        <record id="view_cham_cong_tree" model="ir.ui.view">
            <field name="name">cham_cong.tree</field>
            <field name="model">cham_cong</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="nhan_vien_id"/>
                    <field name="thang"/>
                    <field name="nam"/>
                    <field name="so_ngay_cong_chuan"/>
                    <field name="so_ngay_cong_thuc_te"/>
                    <field name="so_ngay_nghi_phep"/>
                    <field name="so_ngay_nghi_khong_luong"/>
                    <field name="so_gio_lam_them"/>
                    <field name="he_so_cong"/>
                </tree>
            </field>
        </record>

        <record id="view_cham_cong_search" model="ir.ui.view">
            <field name="name">cham_cong.search</field>
            <field name="model">cham_cong</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm chấm công">
                    <field name="nhan_vien_id"/>
                    <field name="thang"/>
                    <field name="nam"/>
                    <group expand="0" string="Nhóm theo">
                        <filter string="Nhân viên" name="group_nv" context="{'group_by': 'nhan_vien_id'}"/>
                        <filter string="Tháng" name="group_thang" context="{'group_by': 'thang'}"/>
                        <filter string="Năm" name="group_nam" context="{'group_by': 'nam'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_cham_cong" model="ir.actions.act_window">
            <field name="name">Bảng chấm công</field>
            <field name="res_model">cham_cong</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_cham_cong_search"/>
        </record>
    </data>
</odoo>
