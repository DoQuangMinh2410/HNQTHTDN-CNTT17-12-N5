<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_tai_khoan_form" model="ir.ui.view">
            <field name="name">tai_khoan_ke_toan.form</field>
            <field name="model">tai_khoan_ke_toan</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="ma_tai_khoan" placeholder="Mã TK (vd: 111)"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="ten_tai_khoan"/>
                                <field name="loai_tai_khoan"/>
                            </group>
                            <group>
                                <field name="so_du" class="oe_read_only" style="font-weight:bold;"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Chi tiết phát sinh">
                                <field name="chi_tiet_ids" readonly="1">
                                    <tree>
                                        <field name="ngay_ghi_so"/>
                                        <field name="but_toan_id"/>
                                        <field name="dien_giai"/>
                                        <field name="loai"/>
                                        <field name="so_tien"/>
                                        <field name="trang_thai"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tai_khoan_tree" model="ir.ui.view">
            <field name="name">tai_khoan_ke_toan.tree</field>
            <field name="model">tai_khoan_ke_toan</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ma_tai_khoan"/>
                    <field name="ten_tai_khoan"/>
                    <field name="loai_tai_khoan"/>
                    <field name="so_du" sum="Tổng số dư"/>
                </tree>
            </field>
        </record>

        <record id="view_tai_khoan_search" model="ir.ui.view">
            <field name="name">tai_khoan_ke_toan.search</field>
            <field name="model">tai_khoan_ke_toan</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm tài khoản">
                    <field name="ma_tai_khoan"/>
                    <field name="ten_tai_khoan"/>
                    <field name="loai_tai_khoan"/>
                    <group expand="0" string="Nhóm theo">
                        <filter string="Loại tài khoản" name="group_loai" context="{'group_by': 'loai_tai_khoan'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_tai_khoan" model="ir.actions.act_window">
            <field name="name">Hệ thống Tài khoản</field>
            <field name="res_model">tai_khoan_ke_toan</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_tai_khoan_search"/>
        </record>
    </data>
</odoo>
