<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="asset_gemini_config_form" model="ir.ui.view">
            <field name="name">asset.gemini.config.form</field>
            <field name="model">asset.gemini.config</field>
            <field name="arch" type="xml">
                <form string="Cấu hình Google Gemini">
                    <header>
                        <button name="action_test_connection" string="Test Kết nối" type="object" class="oe_highlight"/>
                    </header>
                    <sheet>
                        <div class="alert alert-info" role="alert">
                            <p><strong>📌 Hướng dẫn:</strong></p>
                            <ol>
                                <li>Truy cập: <a href="https://aistudio.google.com/app/apikeys" target="_blank">https://aistudio.google.com/app/apikeys</a></li>
                                <li>Tạo API Key mới (nếu chưa có)</li>
                                <li>Copy API Key vào trường "API Key Google Gemini" dưới đây</li>
                                <li>Nhấn "Test Kết nối" để xác nhận</li>
                            </ol>
                        </div>
                        
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="is_active"/>
                                <field name="is_configured" readonly="1"/>
                            </group>
                        </group>

                        <group string="Cấu Hình API">
                            <group>
                                <field name="gemini_api_key" password="True" required="True" placeholder="sk-..."/>
                                <field name="model_name"/>
                                <field name="language"/>
                            </group>
                            <group>
                                <field name="temperature"/>
                                <field name="max_tokens"/>
                            </group>
                        </group>

                        <group string="Trạng Thái Kết Nối">
                            <group>
                                <field name="last_test" readonly="1"/>
                                <field name="test_status" readonly="1" widget="badge"/>
                                <field name="test_message" readonly="1" nolabel="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="asset_gemini_config_tree" model="ir.ui.view">
            <field name="name">asset.gemini.config.tree</field>
            <field name="model">asset.gemini.config</field>
            <field name="arch" type="xml">
                <tree string="Danh sách Cấu hình">
                    <field name="name"/>
                    <field name="model_name"/>
                    <field name="is_configured"/>
                    <field name="is_active"/>
                    <field name="test_status"/>
                </tree>
            </field>
        </record>

        <!-- Action -->
        <record id="asset_gemini_config_action" model="ir.actions.act_window">
            <field name="name">Cấu hình Google Gemini AI</field>
            <field name="res_model">asset.gemini.config</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
