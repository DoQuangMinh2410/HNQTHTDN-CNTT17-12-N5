<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Notification Log Form View -->
        <record id="notification_log_form" model="ir.ui.view">
            <field name="name">notification.log.form</field>
            <field name="model">notification.log</field>
            <field name="arch" type="xml">
                <form string="Chi tiết Thông báo">
                    <header>
                        <button name="action_retry" string="🔄 Thử lại" type="object" states="failed" class="oe_highlight"/>
                        <button name="action_cancel" string="❌ Hủy" type="object" states="pending"/>
                    </header>
                    <sheet>
                        <div class="row">
                            <div class="col-sm-6">
                                <strong>Trạng thái:</strong> <span class="badge" attrs="{'class': [('pending', 'badge-warning'), ('sent', 'badge-success'), ('failed', 'badge-danger'), ('cancelled', 'badge-secondary')].get(status, 'badge-secondary')}"><field name="status"/></span>
                            </div>
                            <div class="col-sm-6">
                                <strong>Loại sự kiện:</strong> <field name="event_type" readonly="1"/>
                            </div>
                        </div>

                        <group>
                            <group>
                                <field name="subject"/>
                                <field name="notification_type" widget="radio"/>
                                <field name="retry_count" readonly="1"/>
                            </group>
                        </group>

                        <group string="👥 Người nhận">
                            <group>
                                <field name="email_to" attrs="{'invisible': [('notification_type', '=', 'sms')]}"/>
                                <field name="sms_to" attrs="{'invisible': [('notification_type', '=', 'email')]}"/>
                            </group>
                        </group>

                        <group string="📧 Email Content" attrs="{'invisible': [('notification_type', '=', 'sms')]}">
                            <group>
                                <field name="subject_line"/>
                                <field name="email_provider" readonly="1"/>
                                <field name="email_external_id" readonly="1"/>
                            </group>
                            <group>
                                <field name="email_body" nolabel="1" attrs="{'invisible': [('notification_type', '=', 'sms')]}"/>
                            </group>
                        </group>

                        <group string="💬 SMS Content" attrs="{'invisible': [('notification_type', '=', 'email')]}">
                            <group>
                                <field name="sms_message" nolabel="1" help="Tối đa 160 ký tự"/>
                                <field name="sms_provider" readonly="1"/>
                                <field name="sms_external_id" readonly="1"/>
                            </group>
                        </group>

                        <group string="📎 Liên kết">
                            <group>
                                <field name="asset_id"/>
                                <field name="depreciation_schedule_id"/>
                                <field name="analysis_id"/>
                            </group>
                        </group>

                        <group string="⏱️ Thời gian">
                            <group>
                                <field name="scheduled_datetime"/>
                                <field name="sent_datetime" readonly="1"/>
                            </group>
                        </group>

                        <group string="❌ Lỗi" attrs="{'invisible': [('status', '!=', 'failed')]}">
                            <group>
                                <field name="error_message" readonly="1" nolabel="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Notification Log Tree View -->
        <record id="notification_log_tree" model="ir.ui.view">
            <field name="name">notification.log.tree</field>
            <field name="model">notification.log</field>
            <field name="arch" type="xml">
                <tree string="Nhật ký Thông báo">
                    <field name="subject"/>
                    <field name="notification_type" widget="badge"/>
                    <field name="event_type" widget="badge"/>
                    <field name="email_to"/>
                    <field name="sms_to"/>
                    <field name="status" widget="badge"/>
                    <field name="create_date"/>
                </tree>
            </field>
        </record>

        <!-- Notification Log Search View -->
        <record id="notification_log_search" model="ir.ui.view">
            <field name="name">notification.log.search</field>
            <field name="model">notification.log</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm Thông báo">
                    <field name="subject"/>
                    <field name="email_to"/>
                    <field name="sms_to"/>
                    <field name="event_type"/>
                    <separator/>
                    <filter name="sent" string="Đã gửi" domain="[('status', '=', 'sent')]"/>
                    <filter name="pending" string="Chờ gửi" domain="[('status', '=', 'pending')]"/>
                    <filter name="failed" string="Lỗi" domain="[('status', '=', 'failed')]"/>
                    <filter name="email_type" string="Email" domain="[('notification_type', 'in', ['email', 'email_sms'])]"/>
                    <filter name="sms_type" string="SMS" domain="[('notification_type', 'in', ['sms', 'email_sms'])]"/>
                    <filter name="depreciation" string="Khấu hao" domain="[('event_type', '=', 'depreciation_completed')]"/>
                    <filter name="anomaly" string="Bất thường" domain="[('event_type', '=', 'anomaly_detected')]"/>
                    <filter name="expires_soon" string="Sắp hết hạn" domain="[('event_type', '=', 'asset_expires_soon')]"/>
                    <separator/>
                    <filter name="today" string="Hôm nay" domain="[('create_date', '>=', (context_today() - timedelta(days=1)).strftime('%Y-%m-%d')), ('create_date', '&lt;', context_today().strftime('%Y-%m-%d'))]"/>
                    <filter name="week" string="Tuần này" domain="[('create_date', '>=', (context_today() - timedelta(weeks=1)).strftime('%Y-%m-%d'))]"/>
                    <separator/>
                    <group expand="1" string="Nhóm theo">
                        <filter name="group_status" string="Trạng thái" context="{'group_by': 'status'}"/>
                        <filter name="group_event" string="Loại sự kiện" context="{'group_by': 'event_type'}"/>
                        <filter name="group_type" string="Loại thông báo" context="{'group_by': 'notification_type'}"/>
                        <filter name="group_date" string="Ngày tạo" context="{'group_by': 'create_date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Notification Log Action -->
        <record id="notification_log_action" model="ir.actions.act_window">
            <field name="name">Nhật ký Thông báo</field>
            <field name="res_model">notification.log</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'search_default_sent': 1}</field>
        </record>

        <!-- Menu Item -->
        <menuitem id="notification_log_menu" name="Nhật ký Thông báo" parent="accounting_module_root" action="notification_log_action" sequence="6"/>
    </data>
</odoo>
