<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Scheduled job for monthly depreciation -->
        <record id="ir_cron_monthly_depreciation" model="ir.cron">
            <field name="name">Monthly Asset Depreciation</field>
            <field name="model_id" ref="model_tai_san"/>
            <field name="state">code</field>
            <field name="code">model.schedule_monthly_depreciation()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="nextcall">2026-04-01 00:00:00</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>